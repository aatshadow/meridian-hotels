{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/meridian/:path*", "destination": "/meridian/index.html" },
    { "source": "/chaika/:path*", "destination": "/chaika/index.html" },
    { "source": "/calypso/:path*", "destination": "/calypso/index.html" },
    { "source": "/oman/:path*", "destination": "/oman/index.html" },
    { "source": "/surf/:path*", "destination": "/surf/index.html" },
    { "source": "/primo/:path*", "destination": "/primo/index.html" }
  ]
}
